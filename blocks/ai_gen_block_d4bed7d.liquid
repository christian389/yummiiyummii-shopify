{% doc %}
  @prompt
    can you make me a hero section with an image or video background with the option to add a different backgorund on mobile. I would still like a headline and subheading and a review bar and a cta. I would like to be able to customize the allignment of it all , please make sure i can control where in the section the text should show, the review bar should be above the headline - and the cta should be size controable, Make the whole design more responsive, i need to be able to upload videos as well 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.min_height_desktop }}px;
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    justify-content: {{ block.settings.horizontal_alignment }};
    overflow: hidden;
  }

  .ai-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-background-{{ ai_gen_id }} img,
  .ai-hero-background-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-hero-background-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-hero-content-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: {{ block.settings.content_max_width }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-hero-review-bar-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    gap: 8px;
    margin-bottom: {{ block.settings.review_spacing }}px;
  }

  .ai-hero-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-hero-stars-{{ ai_gen_id }} svg {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-hero-review-text-{{ ai_gen_id }} {
    color: {{ block.settings.review_text_color }};
    font-size: {{ block.settings.review_text_size }}px;
    font-weight: 500;
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    color: {{ block.settings.headline_color }};
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
  }

  .ai-hero-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.5;
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
  }

  .ai-hero-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background_color }};
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
  }

  .ai-hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background_color }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-hero-background-desktop-{{ ai_gen_id }} {
      {% if block.settings.background_mobile_image or block.settings.background_mobile_video %}
        display: none;
      {% endif %}
    }

    .ai-hero-background-mobile-{{ ai_gen_id }} {
      {% if block.settings.background_mobile_image or block.settings.background_mobile_video %}
        display: block;
      {% endif %}
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
    }

    .ai-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
    }

    .ai-hero-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_font_size_mobile }}px;
      padding: {{ block.settings.cta_padding_vertical_mobile }}px {{ block.settings.cta_padding_horizontal_mobile }}px;
    }

    .ai-hero-stars-{{ ai_gen_id }} svg {
      width: {{ block.settings.star_size_mobile }}px;
      height: {{ block.settings.star_size_mobile }}px;
    }

    .ai-hero-review-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.review_text_size_mobile }}px;
    }
  }
{% endstyle %}

<ai-hero-{{ ai_gen_id }} class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-background-{{ ai_gen_id }} ai-hero-background-desktop-{{ ai_gen_id }}">
    {% if block.settings.background_desktop_video %}
      {% if block.settings.background_desktop_video.sources[0].url %}
        <video autoplay muted loop playsinline>
          <source src="{{ block.settings.background_desktop_video.sources[0].url }}" type="{{ block.settings.background_desktop_video.sources[0].mime_type }}">
        </video>
      {% endif %}
    {% elsif block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.background_mobile_image or block.settings.background_mobile_video %}
    <div class="ai-hero-background-{{ ai_gen_id }} ai-hero-background-mobile-{{ ai_gen_id }}">
      {% if block.settings.background_mobile_video %}
        {% if block.settings.background_mobile_video.sources[0].url %}
          <video autoplay muted loop playsinline>
            <source src="{{ block.settings.background_mobile_video.sources[0].url }}" type="{{ block.settings.background_mobile_video.sources[0].mime_type }}">
          </video>
        {% endif %}
      {% elsif block.settings.background_mobile_image %}
        <img
          src="{{ block.settings.background_mobile_image | image_url: width: 1000 }}"
          alt="{{ block.settings.background_mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.background_mobile_image.width }}"
          height="{{ block.settings.background_mobile_image.height }}"
        >
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-content-wrapper-{{ ai_gen_id }}">
    {% if block.settings.show_review_bar %}
      <div class="ai-hero-review-bar-{{ ai_gen_id }}">
        <div class="ai-hero-stars-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
        </div>
        {% if block.settings.review_text != blank %}
          <span class="ai-hero-review-text-{{ ai_gen_id }}">{{ block.settings.review_text }}</span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-hero-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    {% if block.settings.cta_text != blank %}
      <a href="{{ block.settings.cta_link }}" class="ai-hero-cta-{{ ai_gen_id }}">
        {{ block.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</ai-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class AiHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('ai-hero-{{ ai_gen_id }}', AiHero{{ ai_gen_id }});
  })();
</script>


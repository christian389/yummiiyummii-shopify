{% doc %}
  @prompt
    create a left/right section with text - a heading,subheading above, body below And to the other side a custom html input field, Make the dektop width ajustable and the alignment of the section as well , i want margin and padding options in top and bottom , also width on mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-content-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.section_alignment }};
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .ai-split-content-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-split-content__wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    flex-direction: {% if block.settings.layout == 'text-left' %}row{% else %}row-reverse{% endif %};
  }

  .ai-split-content__text-column-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-split-content__html-column-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-split-content__subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheading_font.family }}, {{ block.settings.subheading_font.fallback_families }};
    font-weight: {{ block.settings.subheading_font.weight }};
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    text-transform: {{ block.settings.subheading_transform }};
  }

  .ai-split-content__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-split-content__body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: 1.6;
  }

  .ai-split-content__body-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-split-content__html-content-{{ ai_gen_id }} {
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-split-content-container-{{ ai_gen_id }} {
      justify-content: center;
      padding-top: {{ block.settings.padding_top | times: 0.7 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.7 }}px;
      margin-top: {{ block.settings.margin_top | times: 0.7 }}px;
      margin-bottom: {{ block.settings.margin_bottom | times: 0.7 }}px;
    }

    .ai-split-content-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width_percent }}%;
    }

    .ai-split-content__wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }

    .ai-split-content__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-split-content__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }

    .ai-split-content__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-split-content-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-content-{{ ai_gen_id }}">
    <div class="ai-split-content__wrapper-{{ ai_gen_id }}">
      <div class="ai-split-content__text-column-{{ ai_gen_id }}">
        {% if block.settings.subheading != blank %}
          <p class="ai-split-content__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-split-content__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.body != blank %}
          <div class="ai-split-content__body-{{ ai_gen_id }}">
            {{ block.settings.body }}
          </div>
        {% endif %}
      </div>

      <div class="ai-split-content__html-column-{{ ai_gen_id }}">
        {% if block.settings.custom_html != blank %}
          <div class="ai-split-content__html-content-{{ ai_gen_id }}">
            {{ block.settings.custom_html }}
          </div>
        {% else %}
          <div class="ai-split-content__html-content-{{ ai_gen_id }}" style="padding: 40px; background-color: #f4f4f4; border-radius: 8px; text-align: center; color: #999;">
            Add custom HTML content
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Split content",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "text-left",
          "label": "Text left, HTML right"
        },
        {
          "value": "text-right",
          "label": "Text right, HTML left"
        }
      ],
      "default": "text-left"
    },
    {
      "type": "select",
      "id": "section_alignment",
      "label": "Section alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_width_percent",
      "label": "Mobile width",
      "min": 80,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between columns",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Introducing"
    },
    {
      "type": "font_picker",
      "id": "subheading_font",
      "label": "Font",
      "default": "inter_n3"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "select",
      "id": "subheading_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Split content block"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "instrument_sans_n7"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Body text"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Add your body text here. This section allows you to create a split layout with text on one side and custom HTML content on the other.</p>"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Font",
      "default": "inter_n3"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Spacing between text elements",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Custom HTML"
    },
    {
      "type": "html",
      "id": "custom_html",
      "label": "HTML content"
    }
  ],
  "presets": [
    {
      "name": "Split content"
    }
  ]
}
{% endschema %}

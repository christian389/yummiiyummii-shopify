{% doc %}
  @prompt
    Make a section with text pramarily. I need a centered headline and subheading. and then i need 3 collumns below that with a headline with a subheading for each of the 3 collumns
    and on mobile the 3 collumns should not stack but allign horisontially , We should make the collumns responsive on mobile and show all these collumn without any scrolling section, I need to control the alignment as well for left, center or right alignment, the section should also be changable in terms of alignment when changing desktop width 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-three-column-text-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    {% if block.settings.section_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.section_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.section_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-three-column-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-three-column-text__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-three-column-text__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px 0;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    line-height: 1.2;
  }

  .ai-three-column-text__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-three-column-text__columns-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-three-column-text__column-{{ ai_gen_id }} {
    flex: 1;
    text-align: {{ block.settings.column_alignment }};
  }

  .ai-three-column-text__column-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.column_heading_size }}px;
    color: {{ block.settings.column_heading_color }};
    margin: 0 0 {{ block.settings.column_text_spacing }}px 0;
    font-family: {{ block.settings.column_heading_font.family }}, {{ block.settings.column_heading_font.fallback_families }};
    font-weight: {{ block.settings.column_heading_font.weight }};
    line-height: 1.3;
  }

  .ai-three-column-text__column-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.column_text_size }}px;
    color: {{ block.settings.column_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-three-column-text-wrapper-{{ ai_gen_id }} {
      justify-content: flex-start;
    }

    .ai-three-column-text-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-three-column-text__columns-{{ ai_gen_id }} {
      gap: {{ block.settings.column_gap_mobile }}px;
    }

    .ai-three-column-text__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-three-column-text__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-three-column-text__column-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.column_heading_size | times: 0.9 }}px;
    }

    .ai-three-column-text__column-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.column_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<three-column-text-{{ ai_gen_id }} class="ai-three-column-text-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-three-column-text-{{ ai_gen_id }}">
    <div class="ai-three-column-text__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-three-column-text__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <div class="ai-three-column-text__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}
    </div>

    <div class="ai-three-column-text__columns-{{ ai_gen_id }}">
      <div class="ai-three-column-text__column-{{ ai_gen_id }}">
        {% if block.settings.column_1_heading != blank %}
          <h3 class="ai-three-column-text__column-heading-{{ ai_gen_id }}">{{ block.settings.column_1_heading }}</h3>
        {% endif %}
        {% if block.settings.column_1_text != blank %}
          <div class="ai-three-column-text__column-text-{{ ai_gen_id }}">{{ block.settings.column_1_text }}</div>
        {% endif %}
      </div>

      <div class="ai-three-column-text__column-{{ ai_gen_id }}">
        {% if block.settings.column_2_heading != blank %}
          <h3 class="ai-three-column-text__column-heading-{{ ai_gen_id }}">{{ block.settings.column_2_heading }}</h3>
        {% endif %}
        {% if block.settings.column_2_text != blank %}
          <div class="ai-three-column-text__column-text-{{ ai_gen_id }}">{{ block.settings.column_2_text }}</div>
        {% endif %}
      </div>

      <div class="ai-three-column-text__column-{{ ai_gen_id }}">
        {% if block.settings.column_3_heading != blank %}
          <h3 class="ai-three-column-text__column-heading-{{ ai_gen_id }}">{{ block.settings.column_3_heading }}</h3>
        {% endif %}
        {% if block.settings.column_3_text != blank %}
          <div class="ai-three-column-text__column-text-{{ ai_gen_id }}">{{ block.settings.column_3_text }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</three-column-text-{{ ai_gen_id }}>

<script>
  (function() {
    class ThreeColumnText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('three-column-text-{{ ai_gen_id }}', ThreeColumnText{{ ai_gen_id }});
  })();
</script>


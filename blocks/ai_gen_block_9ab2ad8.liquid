{% doc %}
  @prompt
    create a hero section for lifestyle brand. Big image background with text in the bottom left, Tilføj ratings lige over overskriften 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.height_desktop }}px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .ai-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding: {{ block.settings.content_padding }}px;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-hero-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: {{ block.settings.rating_spacing }}px;
  }

  .ai-hero-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-hero-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-hero-star-empty-{{ ai_gen_id }} {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-hero-rating-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.rating_text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    line-height: 1.1;
    font-weight: 700;
  }

  .ai-hero-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    line-height: 1.4;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.height_mobile }}px;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.6 }}px;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }

    .ai-hero-star-{{ ai_gen_id }} {
      width: {{ block.settings.star_size | times: 0.8 }}px;
      height: {{ block.settings.star_size | times: 0.8 }}px;
    }

    .ai-hero-rating-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.rating_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-empty-state-{{ ai_gen_id }}">
          Tilføj et baggrundsbillede for at komme i gang
        </div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_overlay %}
    <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-hero-content-{{ ai_gen_id }}">
    {% if block.settings.show_rating %}
      <div class="ai-hero-rating-{{ ai_gen_id }}">
        <div class="ai-hero-stars-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            <svg
              class="ai-hero-star-{{ ai_gen_id }} {% if i > block.settings.rating_value %}ai-hero-star-empty-{{ ai_gen_id }}{% endif %}"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
        </div>
        {% if block.settings.rating_text != blank %}
          <span class="ai-hero-rating-text-{{ ai_gen_id }}">{{ block.settings.rating_text }}</span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-hero-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-hero-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Hero lifestyle",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Billede"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Baggrundsbillede"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop højde",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobil højde",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Vis overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay farve",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay gennemsigtighed",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Vis rating",
      "default": true
    },
    {
      "type": "range",
      "id": "rating_value",
      "label": "Antal stjerner",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating tekst",
      "default": "5.0 (2.500+ anmeldelser)"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Stjerne størrelse",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Stjerne farve",
      "default": "#FFD700"
    },
    {
      "type": "color",
      "id": "star_empty_color",
      "label": "Tom stjerne farve",
      "default": "#CCCCCC"
    },
    {
      "type": "range",
      "id": "rating_text_size",
      "label": "Rating tekst størrelse",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "rating_spacing",
      "label": "Afstand under rating",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Indhold"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Overskrift",
      "default": "Opdag din stil"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Løft din hverdag med vores kuraterede kollektion"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Overskrift størrelse",
      "min": 24,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Underoverskrift størrelse",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekst farve",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Tekst afstand",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Indhold padding",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Indhold max bredde",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "header",
      "content": "Knap"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Knap tekst",
      "default": "Shop nu"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Knap link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Knap baggrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Knap tekst farve",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover baggrund",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover tekst farve",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Knap skriftstørrelse",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Knap border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Hero lifestyle"
    }
  ]
}
{% endschema %}

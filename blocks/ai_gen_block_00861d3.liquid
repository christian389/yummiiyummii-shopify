{% doc %}
  @prompt
    Just one centered headline
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-centered-headline-{{ ai_gen_id }} {
    text-align: center;
    margin: 0;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
  }

  @media screen and (max-width: 749px) {
    .ai-centered-headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.7);
    }
  }
{% endstyle %}

<h2 class="ai-centered-headline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {{ block.settings.heading }}
</h2>

{% schema %}
{
  "name": "Centered headline",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Your headline here"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Centered headline"
    }
  ]
}
{% endschema %}
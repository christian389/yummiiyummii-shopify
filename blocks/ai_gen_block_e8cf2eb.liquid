    {
      "type": "text",
      "id": "bullet_1_text",
      "label": "Bullet 1 text",
      "default": "Free shipping"
    },
    {
      "type": "text",
      "id": "bullet_2_text",
      "label": "Bullet 2 text",
      "default": "30-day returns"
    },
    {
      "type": "text",
      "id": "bullet_3_text",
      "label": "Bullet 3 text",
      "default": "Secure checkout"
    },
    {
      "type": "range",
      "id": "bullets_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "bullets_icon_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 20
    },
    {
      "type": "range",
      "id": "bullets_gap",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Space between bullets",
      "default": 30
    },
    {
      "type": "color",
      "id": "bullets_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bullets_icon_color",
      "label": "Icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_max_width",

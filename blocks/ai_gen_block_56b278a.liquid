{% doc %}
  @prompt
    Please build me a section that starts with a centered headline at the top, followed by a simple and clean 2x2 grid of four blocks placed in the center of the page. Each block should contain a short headline and a small body text, presented in a clear and easy-to-read way.
    
    Below the four blocks, include a single full-width highlight element that stands out slightly from the rest of the section. This element should feature a large number on the left side and a short descriptive sentence on the right side, creating a clear visual emphasis.
    
    The section should have consistent spacing between the headline, the grid, and the bottom highlight to keep the layout structured and easy to scan.
    
    and please make it mobile friendly 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-feature-grid__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-feature-grid__heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing_after_heading }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    line-height: 1.2;
  }

  .ai-feature-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.spacing_before_highlight }}px;
  }

  .ai-feature-grid__item-{{ ai_gen_id }} {
    background-color: {{ block.settings.item_background }};
    padding: {{ block.settings.item_padding }}px;
    border-radius: {{ block.settings.item_border_radius }}px;
    text-align: {{ block.settings.item_text_align }};
  }

  .ai-feature-grid__item-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_heading_size }}px;
    color: {{ block.settings.item_heading_color }};
    margin: 0 0 {{ block.settings.item_heading_spacing }}px;
    font-family: {{ block.settings.item_heading_font.family }}, {{ block.settings.item_heading_font.fallback_families }};
    font-weight: {{ block.settings.item_heading_font.weight }};
    line-height: 1.3;
  }

  .ai-feature-grid__item-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_text_size }}px;
    color: {{ block.settings.item_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-feature-grid__highlight-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_background }};
    padding: {{ block.settings.highlight_padding }}px;
    border-radius: {{ block.settings.highlight_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
  }

  .ai-feature-grid__highlight-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.highlight_number_size }}px;
    color: {{ block.settings.highlight_number_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    line-height: 1;
    margin: 0;
    flex-shrink: 0;
  }

  .ai-feature-grid__highlight-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.highlight_text_size }}px;
    color: {{ block.settings.highlight_text_color }};
    margin: 0;
    line-height: 1.4;
    flex-grow: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-feature-grid__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
      margin-bottom: {{ block.settings.spacing_after_heading | times: 0.7 }}px;
    }

    .ai-feature-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: {% if block.settings.mobile_columns == '1' %}1fr{% else %}repeat(2, 1fr){% endif %};
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
      margin-bottom: {{ block.settings.spacing_before_highlight | times: 0.7 }}px;
    }

    .ai-feature-grid__item-{{ ai_gen_id }} {
      padding: {{ block.settings.item_padding | times: 0.8 }}px;
    }

    .ai-feature-grid__item-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.item_heading_size }}px * 0.9);
    }

    .ai-feature-grid__item-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.item_text_size }}px * 0.95);
    }

    .ai-feature-grid__highlight-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
      gap: 15px;
      padding: {{ block.settings.highlight_padding | times: 0.7 }}px;
    }

    .ai-feature-grid__highlight-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.highlight_number_size }}px * 0.7);
    }

    .ai-feature-grid__highlight-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.highlight_text_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-feature-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-grid__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-feature-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-feature-grid__grid-{{ ai_gen_id }}">
      {% if block.settings.item_1_heading != blank or block.settings.item_1_text != blank %}
        <div class="ai-feature-grid__item-{{ ai_gen_id }}">
          {% if block.settings.item_1_heading != blank %}
            <h3 class="ai-feature-grid__item-heading-{{ ai_gen_id }}">{{ block.settings.item_1_heading }}</h3>
          {% endif %}
          {% if block.settings.item_1_text != blank %}
            <p class="ai-feature-grid__item-text-{{ ai_gen_id }}">{{ block.settings.item_1_text }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.item_2_heading != blank or block.settings.item_2_text != blank %}
        <div class="ai-feature-grid__item-{{ ai_gen_id }}">
          {% if block.settings.item_2_heading != blank %}
            <h3 class="ai-feature-grid__item-heading-{{ ai_gen_id }}">{{ block.settings.item_2_heading }}</h3>
          {% endif %}
          {% if block.settings.item_2_text != blank %}
            <p class="ai-feature-grid__item-text-{{ ai_gen_id }}">{{ block.settings.item_2_text }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.item_3_heading != blank or block.settings.item_3_text != blank %}
        <div class="ai-feature-grid__item-{{ ai_gen_id }}">
          {% if block.settings.item_3_heading != blank %}
            <h3 class="ai-feature-grid__item-heading-{{ ai_gen_id }}">{{ block.settings.item_3_heading }}</h3>
          {% endif %}
          {% if block.settings.item_3_text != blank %}
            <p class="ai-feature-grid__item-text-{{ ai_gen_id }}">{{ block.settings.item_3_text }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.item_4_heading != blank or block.settings.item_4_text != blank %}
        <div class="ai-feature-grid__item-{{ ai_gen_id }}">
          {% if block.settings.item_4_heading != blank %}
            <h3 class="ai-feature-grid__item-heading-{{ ai_gen_id }}">{{ block.settings.item_4_heading }}</h3>
          {% endif %}
          {% if block.settings.item_4_text != blank %}
            <p class="ai-feature-grid__item-text-{{ ai_gen_id }}">{{ block.settings.item_4_text }}</p>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if block.settings.highlight_number != blank or block.settings.highlight_text != blank %}
      <div class="ai-feature-grid__highlight-{{ ai_gen_id }}">
        {% if block.settings.highlight_number != blank %}
          <div class="ai-feature-grid__highlight-number-{{ ai_gen_id }}">{{ block.settings.highlight_number }}</div>
        {% endif %}
        {% if block.settings.highlight_text != blank %}
          <p class="ai-feature-grid__highlight-text-{{ ai_gen_id }}">{{ block.settings.highlight_text }}</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>


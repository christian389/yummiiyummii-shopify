{% doc %}
  @prompt
    Create collection cards in a carousell section. The cards should contain a image the in the full cart and on top an overlay and cta and text in bottom left, I need to be able to change the image for each collection and adjust margins and paddings for the full section , i would also like to adjust padding and margin for the cards
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    margin-top: {{ block.settings.section_margin_top }}px;
    margin-bottom: {{ block.settings.section_margin_bottom }}px;
  }

  .ai-collection-carousel__wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-left: {{ block.settings.section_padding_left }}px;
    padding-right: {{ block.settings.section_padding_right }}px;
  }

  .ai-collection-carousel__wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 {{ block.settings.card_width }}px;
    height: {{ block.settings.card_height }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease;
    margin-top: {{ block.settings.card_margin_top }}px;
    margin-bottom: {{ block.settings.card_margin_bottom }}px;
    margin-left: {{ block.settings.card_margin_left }}px;
    margin-right: {{ block.settings.card_margin_right }}px;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-collection-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-collection-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-collection-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-collection-card__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.card_padding }}px;
    left: {{ block.settings.card_padding }}px;
    right: {{ block.settings.card_padding }}px;
    bottom: {{ block.settings.card_padding }}px;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%
    );
    pointer-events: none;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-collection-card__content-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.content_padding }}px;
    left: {{ block.settings.content_padding }}px;
    right: {{ block.settings.content_padding }}px;
    z-index: 2;
  }

  .ai-collection-card__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-collection-card__cta-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.cta_text_color }};
    background-color: {{ block.settings.cta_background_color }};
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_size }}px;
    text-decoration: none;
    transition: background-color 0.3s ease;
  }

  .ai-collection-card__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_color }};
  }

  .ai-collection-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_background }};
    color: {{ block.settings.nav_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background-color 0.3s ease;
  }

  .ai-collection-carousel__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_background }};
  }

  .ai-collection-carousel__nav--prev-{{ ai_gen_id }} {
    left: 10px;
  }

  .ai-collection-carousel__nav--next-{{ ai_gen_id }} {
    right: 10px;
  }

  .ai-collection-carousel__nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-collection-card__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-carousel-{{ ai_gen_id }} {
      padding-top: {{ block.settings.section_padding_top | times: 0.7 }}px;
      padding-bottom: {{ block.settings.section_padding_bottom | times: 0.7 }}px;
      margin-top: {{ block.settings.section_margin_top | times: 0.7 }}px;
      margin-bottom: {{ block.settings.section_margin_bottom | times: 0.7 }}px;
    }

    .ai-collection-carousel__wrapper-{{ ai_gen_id }} {
      padding-left: {{ block.settings.section_padding_left | times: 0.5 }}px;
      padding-right: {{ block.settings.section_padding_right | times: 0.5 }}px;
    }

    .ai-collection-card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width | times: 0.8 }}px;
      height: {{ block.settings.card_height | times: 0.8 }}px;
      margin-top: {{ block.settings.card_margin_top | times: 0.7 }}px;
      margin-bottom: {{ block.settings.card_margin_bottom | times: 0.7 }}px;
      margin-left: {{ block.settings.card_margin_left | times: 0.7 }}px;
      margin-right: {{ block.settings.card_margin_right | times: 0.7 }}px;
    }

    .ai-collection-card__image-{{ ai_gen_id }},
    .ai-collection-card__image-placeholder-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }

    .ai-collection-card__overlay-{{ ai_gen_id }} {
      top: {{ block.settings.card_padding | times: 0.7 }}px;
      left: {{ block.settings.card_padding | times: 0.7 }}px;
      right: {{ block.settings.card_padding | times: 0.7 }}px;
      bottom: {{ block.settings.card_padding | times: 0.7 }}px;
    }

    .ai-collection-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-collection-card__cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<collection-carousel-{{ ai_gen_id }}
  class="ai-collection-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.show_nav %}
    <button
      class="ai-collection-carousel__nav-{{ ai_gen_id }} ai-collection-carousel__nav--prev-{{ ai_gen_id }}"
      aria-label="Previous"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
  {% endif %}

  <div class="ai-collection-carousel__wrapper-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign image_key = 'collection_' | append: i | append: '_image'
        assign collection = block.settings[collection_key]
        assign custom_image = block.settings[image_key]
      %}

      {% if collection != blank %}
        <a
          href="{{ collection.url }}"
          class="ai-collection-card-{{ ai_gen_id }}"
        >
          {% if custom_image %}
            <img
              src="{{ custom_image | image_url: width: 800 }}"
              alt="{{ custom_image.alt | escape }}"
              class="ai-collection-card__image-{{ ai_gen_id }}"
              loading="lazy"
              width="800"
              height="600"
            >
          {% elsif collection.featured_image %}
            <img
              src="{{ collection.featured_image | image_url: width: 800 }}"
              alt="{{ collection.featured_image.alt | escape }}"
              class="ai-collection-card__image-{{ ai_gen_id }}"
              loading="lazy"
              width="800"
              height="600"
            >
          {% else %}
            <div class="ai-collection-card__image-placeholder-{{ ai_gen_id }}">
              {{ 'collection-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="ai-collection-card__overlay-{{ ai_gen_id }}"></div>

          <div class="ai-collection-card__content-{{ ai_gen_id }}">
            <h3 class="ai-collection-card__title-{{ ai_gen_id }}">
              {{ collection.title }}
            </h3>
            <span class="ai-collection-card__cta-{{ ai_gen_id }}">
              {{ block.settings.cta_text }}
            </span>
          </div>
        </a>
      {% else %}
        <div class="ai-collection-card-{{ ai_gen_id }}">
          <div class="ai-collection-card__image-placeholder-{{ ai_gen_id }}">
            {{ 'collection-1' | placeholder_svg_tag }}
            <div class="ai-collection-card__empty-state-{{ ai_gen_id }}">
              Next, add a collection
            </div>
          </div>
          <div class="ai-collection-card__overlay-{{ ai_gen_id }}"></div>
          <div class="ai-collection-card__content-{{ ai_gen_id }}">
            <h3 class="ai-collection-card__title-{{ ai_gen_id }}">
              Collection {{ i }}
            </h3>
            <span class="ai-collection-card__cta-{{ ai_gen_id }}">
              {{ block.settings.cta_text }}
            </span>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if block.settings.show_nav %}
    <button
      class="ai-collection-carousel__nav-{{ ai_gen_id }} ai-collection-carousel__nav--next-{{ ai_gen_id }}"
      aria-label="Next"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  {% endif %}
</collection-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-collection-carousel__wrapper-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-collection-carousel__nav--prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-collection-carousel__nav--next-{{ ai_gen_id }}');

        if (this.prevButton && this.nextButton) {
          this.setupNavigation();
        }
      }

      setupNavigation() {
        this.prevButton.addEventListener('click', () => {
          const scrollAmount = this.wrapper.offsetWidth * 0.8;
          this.wrapper.scrollBy({
            left: -scrollAmount,
            behavior: 'smooth'
          });
        });

        this.nextButton.addEventListener('click', () => {
          const scrollAmount = this.wrapper.offsetWidth * 0.8;
          this.wrapper.scrollBy({
            left: scrollAmount,
            behavior: 'smooth'
          });
        });
      }
    }

    customElements.define('collection-carousel-{{ ai_gen_id }}', CollectionCarousel{{ ai_gen_id }});
  })();
</script>


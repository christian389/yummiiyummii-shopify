{% doc %}
  @prompt
    A hero section that shows text on the left and a image on the right. Add a review blow the button on the right side. And make the button green #4EA286
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-hero-container-{{ ai_gen_id }} {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-hero-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ settings.headings_font_primary.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ settings.headings_line }};
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-hero-text-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ settings.body_font_primary.weight }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ settings.body_line }};
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-hero-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: #4EA286;
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ settings.border_radius_buttons }}px;
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: 500;
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-hero-review-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background-color: {{ block.settings.review_background_color }};
    border-radius: {{ settings.widgets_border_radius }}px;
    border: 1px solid {{ block.settings.review_border_color }};
  }

  .ai-hero-review-avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ai-hero-review-avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-review-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.review_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.text_color }};
    font-size: 20px;
    font-weight: 600;
  }

  .ai-hero-review-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-hero-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
    margin-bottom: 4px;
  }

  .ai-hero-review-star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    color: {{ block.settings.star_color }};
  }

  .ai-hero-review-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px;
    line-height: 1.4;
  }

  .ai-hero-review-author-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color | color_modify: 'alpha', 0.7 }};
    font-weight: 500;
    margin: 0;
  }

  .ai-hero-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.image_height }}px;
    border-radius: {{ settings.widgets_border_radius }}px;
    overflow: hidden;
  }

  .ai-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ settings.color_background_main_secondary }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 6px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-hero-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-hero-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }

    .ai-hero-review-{{ ai_gen_id }} {
      padding: 12px 16px;
    }

    .ai-hero-review-avatar-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-grid-{{ ai_gen_id }}">
      <div class="ai-hero-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-hero-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}

        <div class="ai-hero-button-wrapper-{{ ai_gen_id }}">
          {% if block.settings.button_text != blank %}
            <a href="{{ block.settings.button_link }}" class="ai-hero-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          {% endif %}

          {% if block.settings.show_review %}
            <div class="ai-hero-review-{{ ai_gen_id }}">
              <div class="ai-hero-review-avatar-{{ ai_gen_id }}">
                {% if block.settings.review_avatar %}
                  <img
                    src="{{ block.settings.review_avatar | image_url: width: 96 }}"
                    alt="{{ block.settings.review_author | escape }}"
                    width="96"
                    height="96"
                    loading="lazy"
                  >
                {% else %}
                  <div class="ai-hero-review-placeholder-{{ ai_gen_id }}">
                    {{ block.settings.review_author | slice: 0 | upcase | default: 'U' }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-hero-review-content-{{ ai_gen_id }}">
                <div class="ai-hero-review-stars-{{ ai_gen_id }}">
                  {% for i in (1..5) %}
                    <svg class="ai-hero-review-star-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endfor %}
                </div>
                {% if block.settings.review_text != blank %}
                  <p class="ai-hero-review-text-{{ ai_gen_id }}">"{{ block.settings.review_text }}"</p>
                {% endif %}
                {% if block.settings.review_author != blank %}
                  <p class="ai-hero-review-author-{{ ai_gen_id }}">- {{ block.settings.review_author }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-hero-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-hero-image-{{ ai_gen_id }}"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            loading="lazy"
          >
        {% else %}
          <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-hero-empty-state-{{ ai_gen_id }}">
              Add an image to complete your hero section
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Discover our amazing products and experience quality like never before."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Review"
    },
    {
      "type": "checkbox",
      "id": "show_review",
      "label": "Show review",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "review_avatar",
      "label": "Review avatar"
    },
    {
      "type": "text",
      "id": "review_text",
      "label": "Review text",
      "default": "Amazing quality and fast shipping! Highly recommend."
    },
    {
      "type": "text",
      "id": "review_author",
      "label": "Review author",
      "default": "Sarah M."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#3d8b6f"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#ffd700"
    },
    {
      "type": "color",
      "id": "review_background_color",
      "label": "Review background color",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "review_border_color",
      "label": "Review border color",
      "default": "#e9ecef"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Hero section"
    }
  ]
}
{% endschema %}
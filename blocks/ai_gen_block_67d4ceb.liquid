{% doc %}
  @prompt
    Hero section with full image. Heading og subheading to the right and with a button below. Below the button a review. And above the heading review stars only, Can you place all the text content to the left sorry. And make the stars into trustpilot looking. And could we make vertical scroling images to the right and delete the full background image. The review below the button needs to be with a avatar icon as well, can you make the images into two collumn and the size should match a mobilescreen image. , Make sure that theres 3 images in each imagecollumn and make it loop so there's no whitespace after the last image in each of the collumns. We also need to make the speed much lower
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.section_height }}px;
    display: flex;
    align-items: center;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    max-width: 100%;
    text-align: left;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-stars-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    margin-bottom: 16px;
    justify-content: flex-start;
  }

  .ai-hero-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    margin-right: 2px;
    fill: {{ block.settings.star_color }};
  }

  .ai-hero-star-{{ ai_gen_id }}:last-child {
    margin-right: 8px;
  }

  .ai-hero-trustpilot-text-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: 600;
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ settings.headings_font_primary.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ settings.headings_line }};
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-subheading-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ settings.body_font_primary.weight }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: {{ settings.body_line }};
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ settings.border_radius_buttons }}px;
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ settings.body_font_primary.weight }};
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
    margin-bottom: 24px;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-hero-review-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .ai-hero-avatar-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.avatar_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .ai-hero-avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-avatar-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    fill: {{ block.settings.avatar_icon_color }};
  }

  .ai-hero-review-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-hero-review-text-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ settings.body_font_primary.weight }};
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.5;
    font-style: italic;
    color: {{ block.settings.text_color }};
    opacity: 0.9;
    margin: 0 0 4px;
  }

  .ai-hero-review-author-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: 600;
    font-size: {{ block.settings.review_text_size | minus: 2 }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-hero-images-{{ ai_gen_id }} {
    position: relative;
    height: {{ block.settings.images_height }}px;
    overflow: hidden;
    border-radius: {{ settings.widgets_border_radius }}px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .ai-hero-images-column-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-hero-images-scroll-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    animation: ai-hero-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-hero-images-scroll-{{ ai_gen_id }}--reverse {
    animation: ai-hero-scroll-reverse-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-hero-image-item-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: {{ settings.widgets_border_radius }}px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ai-hero-image-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.5;
  }

  @keyframes ai-hero-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(calc(-50% - 6px));
    }
  }

  @keyframes ai-hero-scroll-reverse-{{ ai_gen_id }} {
    0% {
      transform: translateY(calc(-50% - 6px));
    }
    100% {
      transform: translateY(0);
    }
  }

  .ai-hero-images-column-{{ ai_gen_id }}:hover .ai-hero-images-scroll-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  @media screen and (max-width: 768px) {
    .ai-hero-section-{{ ai_gen_id }} {
      min-height: auto;
      padding: 40px 0;
    }

    .ai-hero-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-hero-images-{{ ai_gen_id }} {
      height: {{ block.settings.images_height | times: 0.7 }}px;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      padding: 14px 28px;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-content-{{ ai_gen_id }}">
      {% if block.settings.show_stars %}
        <div class="ai-hero-stars-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            <svg class="ai-hero-star-{{ ai_gen_id }}" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
          <span class="ai-hero-trustpilot-text-{{ ai_gen_id }}">Trustpilot</span>
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <p class="ai-hero-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-hero-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}

      {% if block.settings.review_text != blank %}
        <div class="ai-hero-review-{{ ai_gen_id }}">
          <div class="ai-hero-avatar-{{ ai_gen_id }}">
            {% if block.settings.avatar_image %}
              <img
                src="{{ block.settings.avatar_image | image_url: width: 100 }}"
                alt="{{ block.settings.review_author | escape }}"
                loading="lazy"
              >
            {% else %}
              <svg viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
              </svg>
            {% endif %}
          </div>
          <div class="ai-hero-review-content-{{ ai_gen_id }}">
            <div class="ai-hero-review-text-{{ ai_gen_id }}">
              "{{ block.settings.review_text }}"
            </div>
            {% if block.settings.review_author != blank %}
              <div class="ai-hero-review-author-{{ ai_gen_id }}">
                - {{ block.settings.review_author }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-hero-images-{{ ai_gen_id }}">
      <div class="ai-hero-images-column-{{ ai_gen_id }}">
        <div class="ai-hero-images-scroll-{{ ai_gen_id }}">
          {% for i in (1..3) %}
            {% liquid
              assign image_key = 'scroll_image_' | append: i
              assign image = block.settings[image_key]
            %}
            <div class="ai-hero-image-item-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 300 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
          {% for i in (1..3) %}
            {% liquid
              assign image_key = 'scroll_image_' | append: i
              assign image = block.settings[image_key]
            %}
            <div class="ai-hero-image-item-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 300 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="ai-hero-images-column-{{ ai_gen_id }}">
        <div class="ai-hero-images-scroll-{{ ai_gen_id }} ai-hero-images-scroll-{{ ai_gen_id }}--reverse">
          {% for i in (4..6) %}
            {% liquid
              assign image_key = 'scroll_image_' | append: i
              assign image = block.settings[image_key]
            %}
            <div class="ai-hero-image-item-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 300 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
          {% for i in (4..6) %}
            {% liquid
              assign image_key = 'scroll_image_' | append: i
              assign image = block.settings[image_key]
            %}
            <div class="ai-hero-image-item-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 300 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 400,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Section height",
      "default": 600
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Trustpilot stars"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show Trustpilot stars",
      "default": true
    },
    {
      "type": "range",
      "id": "star_size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Star size",
      "default": 20
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#00b67a"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our amazing products and exceptional quality"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 18
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Button text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#f25a38"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#d94a2e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Review"
    },
    {
      "type": "textarea",
      "id": "review_text",
      "label": "Review text",
      "default": "Amazing quality and fast shipping! Highly recommend this store to everyone."
    },
    {
      "type": "text",
      "id": "review_author",
      "label": "Review author",
      "default": "Sarah M."
    },
    {
      "type": "range",
      "id": "review_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Review text size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Avatar"
    },
    {
      "type": "image_picker",
      "id": "avatar_image",
      "label": "Avatar image"
    },
    {
      "type": "range",
      "id": "avatar_size",
      "min": 30,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Avatar size",
      "default": 40
    },
    {
      "type": "color",
      "id": "avatar_color",
      "label": "Avatar background color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "avatar_icon_color",
      "label": "Avatar icon color",
      "default": "#999999"
    },
    {
      "type": "header",
      "content": "Scrolling images"
    },
    {
      "type": "range",
      "id": "images_height",
      "min": 300,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Images container height",
      "default": 500
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 30,
      "max": 120,
      "step": 10,
      "unit": "s",
      "label": "Scroll speed",
      "default": 60
    },
    {
      "type": "image_picker",
      "id": "scroll_image_1",
      "label": "Column 1 - Image 1"
    },
    {
      "type": "image_picker",
      "id": "scroll_image_2",
      "label": "Column 1 - Image 2"
    },
    {
      "type": "image_picker",
      "id": "scroll_image_3",
      "label": "Column 1 - Image 3"
    },
    {
      "type": "image_picker",
      "id": "scroll_image_4",
      "label": "Column 2 - Image 1"
    },
    {
      "type": "image_picker",
      "id": "scroll_image_5",
      "label": "Column 2 - Image 2"
    },
    {
      "type": "image_picker",
      "id": "scroll_image_6",
      "label": "Column 2 - Image 3"
    }
  ],
  "presets": [
    {
      "name": "Hero section"
    }
  ]
}
{% endschema %}
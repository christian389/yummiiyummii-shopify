{% doc %}
  @prompt
    Create a full page section with the password field in the middle and with header and subheader and logo above. And a countdown below the password field. , fix the password field. And make it possible to a an image to the background with overlay. Make an extra button below the password field. But the button should be an html input field, so i can create the button myself
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-password-page-{{ ai_gen_id }} {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-password-page-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-password-page__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .ai-password-page__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: {{ block.settings.content_width }}px;
    text-align: center;
  }

  .ai-password-page__logo-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.logo_spacing }}px;
  }

  .ai-password-page__logo-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
  }

  .ai-password-page__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    line-height: 1.2;
  }

  .ai-password-page__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    line-height: 1.5;
  }

  .ai-password-page__form-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.form_spacing }}px;
  }

  .ai-password-page__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  .ai-password-page__input-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.input_width }}px;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    font-size: {{ block.settings.input_font_size }}px;
    text-align: center;
  }

  .ai-password-page__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
  }

  .ai-password-page__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-password-page__submit-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.input_width }}px;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-password-page__submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-password-page__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 14px;
    margin-top: 8px;
  }

  .ai-password-page__custom-button-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.custom_button_spacing }}px;
  }

  .ai-password-page__countdown-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.countdown_gap }}px;
    flex-wrap: wrap;
  }

  .ai-password-page__countdown-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.countdown_item_width }}px;
  }

  .ai-password-page__countdown-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_number_size }}px;
    font-weight: 700;
    color: {{ block.settings.countdown_number_color }};
    line-height: 1;
    margin-bottom: 8px;
  }

  .ai-password-page__countdown-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_label_size }}px;
    color: {{ block.settings.countdown_label_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @media screen and (max-width: 749px) {
    .ai-password-page__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-password-page__subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-password-page__countdown-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.countdown_number_size }}px * 0.7);
    }

    .ai-password-page__logo-{{ ai_gen_id }} img {
      max-width: calc({{ block.settings.logo_width }}px * 0.7);
    }
  }
{% endstyle %}

<password-page-{{ ai_gen_id }} class="ai-password-page-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image %}
    <img
      src="{{ block.settings.background_image | image_url: width: 2000 }}"
      alt="{{ block.settings.background_image.alt | escape }}"
      loading="lazy"
      class="ai-password-page__background-{{ ai_gen_id }}"
    >
  {% endif %}

  <div class="ai-password-page__content-{{ ai_gen_id }}">
    {% if block.settings.logo %}
      <div class="ai-password-page__logo-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          loading="lazy"
        >
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h1 class="ai-password-page__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-password-page__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </div>
    {% endif %}

    <div class="ai-password-page__form-wrapper-{{ ai_gen_id }}">
      {%- form 'storefront_password', class: 'ai-password-page__form-' | append: ai_gen_id -%}
        <input
          type="password"
          name="password"
          class="ai-password-page__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.input_placeholder }}"
          aria-label="Password"
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="ai-password-error-{{ ai_gen_id }}"
          {% endif %}
          required
        >
        
        <button
          type="submit"
          class="ai-password-page__submit-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </button>

        {%- if form.errors -%}
          <div
            id="ai-password-error-{{ ai_gen_id }}"
            class="ai-password-page__error-{{ ai_gen_id }}"
          >
            {{ form.errors.messages.password }}
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>

    {% if block.settings.custom_button_html != blank %}
      <div class="ai-password-page__custom-button-{{ ai_gen_id }}">
        {{ block.settings.custom_button_html }}
      </div>
    {% endif %}

    {% if block.settings.show_countdown %}
      <div class="ai-password-page__countdown-{{ ai_gen_id }}" data-countdown-date="{{ block.settings.countdown_date }}">
        <div class="ai-password-page__countdown-item-{{ ai_gen_id }}">
          <div class="ai-password-page__countdown-number-{{ ai_gen_id }}" data-days>0</div>
          <div class="ai-password-page__countdown-label-{{ ai_gen_id }}">{{ block.settings.countdown_days_label }}</div>
        </div>
        <div class="ai-password-page__countdown-item-{{ ai_gen_id }}">
          <div class="ai-password-page__countdown-number-{{ ai_gen_id }}" data-hours>0</div>
          <div class="ai-password-page__countdown-label-{{ ai_gen_id }}">{{ block.settings.countdown_hours_label }}</div>
        </div>
        <div class="ai-password-page__countdown-item-{{ ai_gen_id }}">
          <div class="ai-password-page__countdown-number-{{ ai_gen_id }}" data-minutes>0</div>
          <div class="ai-password-page__countdown-label-{{ ai_gen_id }}">{{ block.settings.countdown_minutes_label }}</div>
        </div>
        <div class="ai-password-page__countdown-item-{{ ai_gen_id }}">
          <div class="ai-password-page__countdown-number-{{ ai_gen_id }}" data-seconds>0</div>
          <div class="ai-password-page__countdown-label-{{ ai_gen_id }}">{{ block.settings.countdown_seconds_label }}</div>
        </div>
      </div>
    {% endif %}
  </div>
</password-page-{{ ai_gen_id }}>

<script>
  (function() {
    class PasswordPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.countdownElement = this.querySelector('.ai-password-page__countdown-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.countdownElement) {
          this.initCountdown();
        }
      }

      initCountdown() {
        const targetDate = this.countdownElement.getAttribute('data-countdown-date');
        if (!targetDate) return;

        const countdownDate = new Date(targetDate).getTime();
        
        const daysElement = this.countdownElement.querySelector('[data-days]');
        const hoursElement = this.countdownElement.querySelector('[data-hours]');
        const minutesElement = this.countdownElement.querySelector('[data-minutes]');
        const secondsElement = this.countdownElement.querySelector('[data-seconds]');

        const updateCountdown = () => {
          const now = new Date().getTime();
          const distance = countdownDate - now;

          if (distance < 0) {
            daysElement.textContent = '0';
            hoursElement.textContent = '0';
            minutesElement.textContent = '0';
            secondsElement.textContent = '0';
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          daysElement.textContent = days;
          hoursElement.textContent = hours;
          minutesElement.textContent = minutes;
          secondsElement.textContent = seconds;
        };

        updateCountdown();
        setInterval(updateCountdown, 1000);
      }
    }

    customElements.define('password-page-{{ ai_gen_id }}', PasswordPage{{ ai_gen_id }});
  })();
</script>


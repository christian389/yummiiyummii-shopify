{% doc %}
  @prompt
    Please build me a section that starts with a centered headline at the top, followed by a simple and clean 2x2 grid of four blocks placed in the center of the page. Each block should contain a short headline and a small body text, presented in a clear and easy-to-read way.
    
    Below the four blocks, include a single full-width highlight element that stands out slightly from the rest of the section. This element should feature a large number on the left side and a short descriptive sentence on the right side, creating a clear visual emphasis.
    
    The section should have consistent spacing between the headline, the grid, and the bottom highlight to keep the layout structured and easy to scan.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-feature-grid__headline-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.spacing_after_headline }}px 0;
    line-height: 1.2;
  }

  .ai-feature-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.spacing_before_highlight }}px;
  }

  .ai-feature-grid__block-{{ ai_gen_id }} {
    background-color: {{ block.settings.block_background }};
    padding: {{ block.settings.block_padding }}px;
    border-radius: {{ block.settings.block_border_radius }}px;
    text-align: {{ block.settings.block_text_align }};
  }

  .ai-feature-grid__block-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_headline_size }}px;
    color: {{ block.settings.block_headline_color }};
    margin: 0 0 {{ block.settings.block_text_spacing }}px 0;
    line-height: 1.3;
  }

  .ai-feature-grid__block-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_text_size }}px;
    color: {{ block.settings.block_text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-feature-grid__highlight-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    background-color: {{ block.settings.highlight_background }};
    padding: {{ block.settings.highlight_padding }}px;
    border-radius: {{ block.settings.highlight_border_radius }}px;
  }

  .ai-feature-grid__highlight-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.highlight_number_size }}px;
    font-weight: 700;
    color: {{ block.settings.highlight_number_color }};
    line-height: 1;
    flex-shrink: 0;
  }

  .ai-feature-grid__highlight-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.highlight_text_size }}px;
    color: {{ block.settings.highlight_text_color }};
    line-height: 1.4;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-feature-grid__headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.7);
    }

    .ai-feature-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-feature-grid__block-{{ ai_gen_id }} {
      padding: {{ block.settings.block_padding | times: 0.8 }}px;
    }

    .ai-feature-grid__block-headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.block_headline_size }}px * 0.9);
    }

    .ai-feature-grid__block-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.block_text_size }}px * 0.95);
    }

    .ai-feature-grid__highlight-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
      gap: 20px;
      padding: {{ block.settings.highlight_padding | times: 0.7 }}px;
    }

    .ai-feature-grid__highlight-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.highlight_number_size }}px * 0.7);
    }

    .ai-feature-grid__highlight-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.highlight_text_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-feature-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.main_headline != blank %}
    <h2 class="ai-feature-grid__headline-{{ ai_gen_id }}">
      {{ block.settings.main_headline }}
    </h2>
  {% endif %}

  <div class="ai-feature-grid__grid-{{ ai_gen_id }}">
    {% if block.settings.block_1_headline != blank or block.settings.block_1_text != blank %}
      <div class="ai-feature-grid__block-{{ ai_gen_id }}">
        {% if block.settings.block_1_headline != blank %}
          <h3 class="ai-feature-grid__block-headline-{{ ai_gen_id }}">
            {{ block.settings.block_1_headline }}
          </h3>
        {% endif %}
        {% if block.settings.block_1_text != blank %}
          <div class="ai-feature-grid__block-text-{{ ai_gen_id }}">
            {{ block.settings.block_1_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.block_2_headline != blank or block.settings.block_2_text != blank %}
      <div class="ai-feature-grid__block-{{ ai_gen_id }}">
        {% if block.settings.block_2_headline != blank %}
          <h3 class="ai-feature-grid__block-headline-{{ ai_gen_id }}">
            {{ block.settings.block_2_headline }}
          </h3>
        {% endif %}
        {% if block.settings.block_2_text != blank %}
          <div class="ai-feature-grid__block-text-{{ ai_gen_id }}">
            {{ block.settings.block_2_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.block_3_headline != blank or block.settings.block_3_text != blank %}
      <div class="ai-feature-grid__block-{{ ai_gen_id }}">
        {% if block.settings.block_3_headline != blank %}
          <h3 class="ai-feature-grid__block-headline-{{ ai_gen_id }}">
            {{ block.settings.block_3_headline }}
          </h3>
        {% endif %}
        {% if block.settings.block_3_text != blank %}
          <div class="ai-feature-grid__block-text-{{ ai_gen_id }}">
            {{ block.settings.block_3_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.block_4_headline != blank or block.settings.block_4_text != blank %}
      <div class="ai-feature-grid__block-{{ ai_gen_id }}">
        {% if block.settings.block_4_headline != blank %}
          <h3 class="ai-feature-grid__block-headline-{{ ai_gen_id }}">
            {{ block.settings.block_4_headline }}
          </h3>
        {% endif %}
        {% if block.settings.block_4_text != blank %}
          <div class="ai-feature-grid__block-text-{{ ai_gen_id }}">
            {{ block.settings.block_4_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {% if block.settings.highlight_number != blank or block.settings.highlight_text != blank %}
    <div class="ai-feature-grid__highlight-{{ ai_gen_id }}">
      {% if block.settings.highlight_number != blank %}
        <div class="ai-feature-grid__highlight-number-{{ ai_gen_id }}">
          {{ block.settings.highlight_number }}
        </div>
      {% endif %}
      {% if block.settings.highlight_text != blank %}
        <div class="ai-feature-grid__highlight-text-{{ ai_gen_id }}">
          {{ block.settings.highlight_text }}
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>


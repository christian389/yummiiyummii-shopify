olor":"#000000","info_color":"#ffffff","arrow_color":"#000000","arrow_hover_color":"#ffffff","arrow_bg_color":"#ffffff","arrow_bg_hover_color":"#555555","arrow_border_color":"#f6f6f6","arrow_border_hover_color":"#555555","action_color":"#ffffff","action_hover_color":"#ffffff","action_bg_color":"#ffffff","action_bg_hover_color":"#ffffff","action_border_color":"#ffffff","action_border_hover_color":"#ffffff","heading_color":"#000000","sub_heading_color":"#000000","background_color":"#ffffff","background_gradient":"","border_color":"#000000","margin_top":36,"margin_bottom":0,"margin_horizontal":0,"margin_horizontal_mobile":0,"padding_top":0,"padding_bottom":36,"padding_horizontal":5,"padding_horizontal_mobile":1.5,"full_width":true,"content_width":120,"border_thickness":0,"section_radius":20,"lazy":true}},"ss_testimonial_8_gaGeey":{"type":"ss-testimonial-8","blocks":{"slide_xKdPDa":{"type":"slide","settings":{"stars_count":5,"heading":"Dressingtæt madkasse","text":"Endelig lykkedes det mig at finde en plastikfri madkasse til min salat, så jeg kan have madpakken med i rygsækken uden at få dressing ud over det hele 😊","author_date":"Tine"}},"slide_HXL4tb":{"type":"slide","settings":{"stars_count":5,"heading":"Vandflaske til en hver lejlighed …","text":"Jeg har været tester for Yummii Yummii drikkedunk 1 l. Må sige man skal lede længe efter et mere lækkert design. Blankt rustfitstål med bambuslåg. Bæredygtig og lækker. Holder fint på temperaturen om det er ved aftensbordet, på fisketuren eller svampejagt. Bruger den alle steder. Lækkert stilsikkert design. Passer fint ned i rygsækken.","author_date":"Ejner"}},"slide_A9PKRT":{"type":"slide","settings":{"stars_count":5,"heading":"Yummi er det rigtige om deres produkter","text":"Yummi er det rigtige om deres produkter!Så lækre og stilfulde produkter!Deres 600 ml termoflaske med bambuslåg er så god! Jeg har ofte oplevet termoflasker enten blev kolde eller varm uden på afhængig af indholdet. Men denne termoflaske har den samme temperatur udenpå konstant, og er derfor rigtig rar at holde ved og den bliver ikke fugtig\/våd. Indholdet holder også temperaturen næsten hele dagen.","author_date":"Sahana"}},"slide_cPDWB4":{"type":"slide","settings":{"stars_count":5,"heading":"Super lækre produkter og god og hurtig…","text":"Super lækre produkter og god og hurtig service. Har handlet hos Yummi yummi flere gange nu,- og der er altid hurtig levering og produkterne er pakket “lækkert”. Bokse i høj kvalitet, flot design der fungere godt i brug. Har lige købt silikone poser som også er en VIRKLIG lækker kvalitet. Bestemt ikke sidste gang jeg har handlet her. Madpakken smager jo bare bedre, når den er pakket i “lækker” emballage.","author_date":"Anne"}},"slide_PxRdY8":{"type":"slide","settings":{"stars_count":5,"heading":"Meget tilfreds 😊","text":"Jeg var så heldig at skulle anmeldelde en bento large med et rum 😊Endelig en madkasse hvor min kæmpe salat lige kan være i, den kan stå vandret i min rygsæk, holde min mad kold i mere end et par timer, den er miljø venlig, uden alt muligt skadeligt kemi da den er lavet af rustfri stål og virker robust 💚Bestilling og levering gik nemt og hurtigt 😊","author_date":"Annabelle"}},"slide_bCK8kb":{"type":"slide","settings":{"stars_count":5,"heading":"Jeg er vild med termomadkassen!😍","text":"Den er enkel, simpel og meget let at rengør.Var skeptisk for at skulle vaske den op i hånden pga “vanskelige“ og ikke tilgængelig flader at kunne vaske op. MEN det er der ikke. Maden holder sig enten varm eller kold i løbet af dagen... Elsker konceptet om bæredygtighed, miljøbevidste, ingen plastik, kemikalier osv 🌱🌿👏","author_date":"Cathrine"}}},"block_order":["slide_xKdPDa","slide_HXL4tb","slide_A9PKRT","slide_cPDWB4","slide_PxRdY8","slide_bCK8kb"],"settings":{"heading":"","heading_custom":false,"heading_font":"josefin_sans_n4","heading_size":40,"heading_size_mobile":24,"heading_height":130,"heading_align":"center","rating_text":"","rating_text_custom":false,"rating_text_font"
":"rich-text","blocks":{"title_jfxXzi":{"type":"title","settings":{"title":"Fordele ved vores produkter","title_size":"heading-size--small","seo_h_tag":"h2"}},"text_yJ6JNf":{"type":"text","settings":{"text":"<p><strong>Bæredygtighed i Fokus 🌱<br\/><\/strong>Vores produkter er fremstillet af miljøvenlige materialer som rustfrit stål og bambus, hvilket hjælper med at reducere plastikforbrug og skåne miljøet.<\/p><p><\/p><p><strong>Langtidsholdbare produkter 💪<\/strong>Investér i produkter, der kan holde i mange år, og minimer affald samtidig med, at du sparer penge.<\/p><p><\/p><p><strong>Stilfuldt og Funktionelt Design✨<br\/><\/strong>Vores produkter kombinerer elegant design med praktiske løsninger, der gør din hverdag både nemmere og grønnere.<\/p>","text_size":"regular"}}},"block_order":["title_jfxXzi","text_yJ6JNf"],"settings":{"image":"shopify:\/\/shop_images\/Thermobottle_Medium_-_olive-Thermo_Bottles-123-Olive_Night-4_f353df2d-68b8-4028-8b46-fa7f1fb7b879.jpg","image_position":"right","height":"regular","image_crop":true,"is_fullwidth":false,"text_alignment":"horizontal-center","spacing":50,"color_background_main":"rgba(0,0,0,0)","color_text_main":"rgba(0,0,0,0)","color_borders_main":"rgba(0,0,0,0)","border_radius":15,"color_hide_borders":false,"gutter_decrease":true,"remove_margin":true,"remove_bottom_margin":false}},"featured_collection_QmrKyg":{"type":"featured-collection","blocks":{"price_qhpXck":{"type":"price","settings":{}},"title_FCtJrM":{"type":"title","settings":{}},"quick_buy_Jbffgb":{"type":"quick_buy","settings":{"show_only_available":false,"variant_default":true,"show_price":true,"unavailable_variants":"hide"}}},"block_order":["price_qhpXck","title_FCtJrM","quick_buy_Jbffgb"],"settings":{"heading":"Bæredygtige madopbevaringsløsninger til en grønnere hverdag","subheading":"Du får <strong>20% rabat<\/strong> i anledning af skolestart","section_heading_size":"text-size--large","section_heading_layout":"section-heading--center section-heading--two-rows","show_view_all":true,"layout":"grid-3 grid-lap-2 grid-tiny-1","products_number":6,"collection":"all-products","gutter_decrease":false,"seo_h_tag":"h2"}},"rich_text_U6w8E7":{"type":"rich-text","blocks":{"title_mbBHUa":{"type":"title","settings":{"title":"💸 Du sparer lige nu 20% på alle produkter i anledningen af skolestart","title_size":"heading-size--small","seo_h_tag":"h2"}},"text_GBQwJf":{"type":"text","settings":{"text":"<p>Automatisk fratrukket per produkt.<\/p><p><\/p>","text_size":"large"}}},"block_order":["title_mbBHUa","text_GBQwJf"],"settings":{"image_position":"top no-image","height":"regular","image_crop":false,"is_fullwidth":false,"text_alignment":"horizontal-center","spacing":40,"color_background_main":"#54564c","color_text_main":"#ffffff","color_borders_main":"rgba(0,0,0,0)","border_radius":15,"color_hide_borders":false,"gutter_decrease":false,"remove_margin":false,"remove_bottom_margin":false}},"ss_testimonial_8_gaGeey":{"type":"ss-testimonial-8","blocks":{"slide_xKdPDa":{"type":"slide","settings":{"stars_count":5,"heading":"Dressingtæt madkasse","text":"Endelig lykkedes det mig at finde en plastikfri madkasse til min salat, så jeg kan have madpakken med i rygsækken uden at få dressing ud over det hele 😊","author_date":"Tine"}},"slide_HXL4tb":{"type":"slide","settings":{"stars_count":5,"heading":"Vandflaske til en hver lejlighed …","text":"Jeg har været tester for Yummii Yummii drikkedunk 1 l. Må sige man skal lede længe efter et mere lækkert design. Blankt rustfitstål med bambuslåg. Bæredygtig og lækker. Holder fint på temperaturen om det er ved aftensbordet, på fisketuren eller svampejagt. Bruger den alle steder. Lækkert stilsikkert design. Passer fint ned i rygsækken.","author_date":"Ejner"}},"slide_A9PKRT":{"type":"slide","settings":{"stars_count":5,"heading":"Yummi er det rigtige om deres produkter","text":"Yummi er det rigtige om deres produkter!Så lækre og stilfulde produkter!Deres 600 ml termoflaske med bambuslåg er så god! Jeg har ofte oplevet termoflasker enten blev kolde eller varm uden på afhængig af indholdet. Men denne termoflaske har den samme temperatur udenpå konstant, og er derfor rigtig rar at holde ved og den bliver ikke fugtig\/våd. Indholdet holder også temperaturen næsten hele dagen.","author_date":"Sahana"}},"slide_cPDWB4":{"type":"slide","settings":{"stars_count":5,"heading":"Super lækre produkter og god og hurtig…","text":"Super lækre produkter og god og hurtig service. Har handlet hos Yummi yummi flere gange nu,- og der er altid hurtig levering og produkterne er pakket “lækkert”. Bokse i høj kvalitet, flot design der fungere godt i brug. Har lige købt silikone poser som også er en VIRKLIG lækker kvalitet. Bestemt ikke sidste gang jeg har handlet her. Madpakken smager jo bare bedre, når den er pakket i “lækker” emballage.","author_date":"Anne"}},"slide_PxRdY8":{"type":"slide","settings":{"stars_count":5,"heading":"Meget tilfreds 😊","text":"Jeg var så heldig at skulle anmeldelde en bento large med et rum 😊Endelig en madkasse hvor min kæmpe salat lige kan være i, den kan stå vandret i min rygsæk, holde min mad kold i mere end et par timer, den er miljø venlig, uden alt muligt skadeligt kemi da den er lavet af rustfri stål og virker robust 💚Bestilling og levering gik nemt og hurtigt 😊","author_date":"Annabelle"}},"slide_bCK8kb":{"type":"slide","settings":{"stars_count":5,"heading":"Jeg er vild med termomadkassen!😍","text":"Den er enkel, simpel og meget let at rengør.Var skeptisk for at skulle vaske den op i hånden pga “vanskelige“ og ikke tilgængelig flader at kunne vaske op. MEN det er der ikke. Maden holder sig enten varm eller kold i løbet af dagen... Elsker konceptet om bæredygtighed, miljøbevidste, ingen plastik, kemikalier osv 🌱🌿👏","author_date":"Cathrine"}}},"block_order":["slide_xKdPDa","slide_HXL4tb","slide_A9PKRT","slide_cPDWB4","slide_PxRdY8","slide_bCK8kb"],"settings":{"heading":"","heading_custom":false,"heading_font":"josefin_sans_n4","heading_size":40,"heading_size_mobile